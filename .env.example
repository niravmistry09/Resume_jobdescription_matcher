APP_NAME="AI Resume Matcher"
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Future AI provider configuration. Keep real secrets in .env only.
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
MATCHING_MODEL=
SKILL_SCORE_WEIGHT=0.6
SEMANTIC_SCORE_WEIGHT=0.4

# Future persistence configuration.
DATABASE_URL=sqlite:///./resume_matcher.db
